[Unit]
Description=Pi Tablet Telefon backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/pi_tablet_telefon/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/pi_tablet_telefon/backend/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
