import { Button } from "std-widgets.slint";

export struct MenuItem {
    title: string,
    subtitle: string,
    tile-color: color,
    action: string,
}

component AppTile inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <color> tile-color;
    callback clicked;
    background: tile-color;
    border-radius: 8px;
    height: 118px;
    TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        padding: 14px;
        spacing: 8px;
        Text { text: title; font-size: 21px; font-weight: 700; color: #151519; }
        Text { text: subtitle; font-size: 13px; color: #555560; wrap: word-wrap; }
    }
}

component DialKey inherits Rectangle {
    in property <string> digit;
    in property <string> letters;
    callback clicked;
    background: transparent;
    height: 48px;
    TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        spacing: 0px;
        Text { text: digit; font-size: 29px; horizontal-alignment: center; color: #111115; }
        Text { text: letters; font-size: 10px; horizontal-alignment: center; color: #888891; }
    }
}

component SystemNavKey inherits Rectangle {
    in property <string> symbol;
    callback clicked;
    background: transparent;
    height: 46px;
    TouchArea { clicked => { root.clicked(); } }
    Text {
        text: symbol;
        font-size: 25px;
        color: #55555e;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component TabletShell inherits Window {
    title: "Pi Tablet";
    background: tablet-background;
    in-out property <string> tablet-title: "Pi Tablet";
    in-out property <color> tablet-background: #f7f7fa;
    in-out property <[MenuItem]> menu-items;
    in-out property <string> screen: "home";
    in-out property <string> dialed: "";
    in-out property <string> status: "Hazir";
    in-out property <bool> in-call: false;
    in-out property <string> contact-name: "";
    in-out property <string> last-reply: "";
    in-out property <bool> listening: false;
    in-out property <string> phone-view: "keypad";
    in-out property <string> suggested-name: "";
    in-out property <string> suggested-phone: "";
    in-out property <int> volume-percent: 150;
    callback open-app(string);
    callback phone-tone(string);
    callback set-volume(int);
    callback test-sound;
    callback start-call(string);
    callback send-message(string);
    callback listen;
    callback end-call;

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        HorizontalLayout {
            height: 44px;
            Text { text: screen == "home" ? tablet-title : screen == "phone" ? "Telefon" : screen == "settings" ? "Ses ayarlari" : "Son uygulamalar"; font-size: 28px; font-weight: 700; color: #111115; }
            Text { horizontal-stretch: 1; text: status; horizontal-alignment: right; vertical-alignment: center; color: #676772; font-size: 13px; }
        }

        if screen == "home": VerticalLayout {
            spacing: 12px;
            GridLayout {
                spacing: 12px;
                for item[index] in menu-items: AppTile {
                    row: index / 2;
                    col: Math.mod(index, 2);
                    title: item.title;
                    subtitle: item.action == "settings" ? volume-percent + "%" : item.subtitle;
                    tile-color: item.tile-color;
                    clicked => { root.open-app(item.action); }
                }
            }
        }

        if screen == "phone": VerticalLayout {
            spacing: 6px;
            if !in-call && phone-view == "keypad": VerticalLayout {
                spacing: 5px;
                if suggested-name != "": Rectangle {
                    height: 48px;
                    background: #ffffff;
                    border-color: #dedee4;
                    border-width: 1px;
                    border-radius: 8px;
                    TouchArea { clicked => { dialed = suggested-phone; } }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        Text { text: suggested-name; font-size: 16px; font-weight: 700; color: #151519; vertical-alignment: center; }
                        Text { horizontal-stretch: 1; text: suggested-phone; font-size: 12px; color: #777781; horizontal-alignment: right; vertical-alignment: center; }
                    }
                }
                Rectangle { height: 44px; background: transparent; Text { text: dialed; font-size: 30px; horizontal-alignment: center; vertical-alignment: center; color: #151519; } }
                GridLayout {
                    height: suggested-name == "" ? 212px : 186px;
                    spacing: 3px;
                    DialKey { row: 0; col: 0; digit: "1"; letters: ""; clicked => { dialed += "1"; root.phone-tone("1"); } }
                    DialKey { row: 0; col: 1; digit: "2"; letters: "ABC"; clicked => { dialed += "2"; root.phone-tone("2"); } }
                    DialKey { row: 0; col: 2; digit: "3"; letters: "DEF"; clicked => { dialed += "3"; root.phone-tone("3"); } }
                    DialKey { row: 1; col: 0; digit: "4"; letters: "GHI"; clicked => { dialed += "4"; root.phone-tone("4"); } }
                    DialKey { row: 1; col: 1; digit: "5"; letters: "JKL"; clicked => { dialed += "5"; root.phone-tone("5"); } }
                    DialKey { row: 1; col: 2; digit: "6"; letters: "MNO"; clicked => { dialed += "6"; root.phone-tone("6"); } }
                    DialKey { row: 2; col: 0; digit: "7"; letters: "PQRS"; clicked => { dialed += "7"; root.phone-tone("7"); } }
                    DialKey { row: 2; col: 1; digit: "8"; letters: "TUV"; clicked => { dialed += "8"; root.phone-tone("8"); } }
                    DialKey { row: 2; col: 2; digit: "9"; letters: "WXYZ"; clicked => { dialed += "9"; root.phone-tone("9"); } }
                    DialKey { row: 3; col: 0; digit: "*"; letters: ""; clicked => { dialed += "*"; root.phone-tone("star"); } }
                    DialKey { row: 3; col: 1; digit: "0"; letters: "+"; clicked => { dialed += "0"; root.phone-tone("0"); } }
                    DialKey { row: 3; col: 2; digit: "#"; letters: ""; clicked => { dialed += "#"; root.phone-tone("hash"); } }
                }
                HorizontalLayout {
                    height: 58px;
                    Rectangle { horizontal-stretch: 1; background: transparent; }
                    Rectangle {
                        width: 58px;
                        background: #0aaa68;
                        border-radius: 29px;
                        Text { text: "Ara"; color: white; font-size: 16px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea { clicked => { status = dialed == "" ? "Asya AI araniyor..." : dialed + " araniyor..."; root.start-call(dialed); } }
                    }
                    Rectangle { horizontal-stretch: 1; background: transparent; }
                    Button { visible: dialed != ""; width: 58px; text: "Sil"; clicked => { dialed = ""; suggested-name = ""; suggested-phone = ""; } }
                }
            }
            if !in-call && phone-view == "contacts": VerticalLayout {
                spacing: 5px;
                Text { text: "Kisiler"; font-size: 22px; font-weight: 700; color: #151519; height: 32px; }
                GridLayout {
                height: 246px;
                spacing: 8px;
                Button { row: 0; col: 0; text: "Asya AI"; clicked => { dialed = ""; root.start-call(""); } }
                Button { row: 0; col: 1; text: "Deniz AI"; clicked => { dialed = "+905332022020"; root.start-call(dialed); } }
                Button { row: 1; col: 0; text: "Mira AI"; clicked => { dialed = "+905343033030"; root.start-call(dialed); } }
                Button { row: 1; col: 1; text: "Atlas AI"; clicked => { dialed = "+905354044040"; root.start-call(dialed); } }
                Button { row: 2; col: 0; text: "Zeynep AI"; clicked => { dialed = "+905365055050"; root.start-call(dialed); } }
                Button { row: 2; col: 1; text: "Kerem AI"; clicked => { dialed = "+905376066060"; root.start-call(dialed); } }
                }
            }
            if !in-call && phone-view == "recent": VerticalLayout {
                spacing: 8px;
                Text { text: "Son aramalar"; font-size: 22px; font-weight: 700; color: #151519; height: 32px; }
                Button { text: "Asya AI    Bugun"; clicked => { dialed = ""; root.start-call(""); } }
                Button { text: "Mira AI    Dun"; clicked => { dialed = "+905343033030"; root.start-call(dialed); } }
                Button { text: "Deniz AI    Dun"; clicked => { dialed = "+905332022020"; root.start-call(dialed); } }
            }
            if in-call: Rectangle {
                background: #e8f6ef;
                border-radius: 8px;
                height: 86px;
                VerticalLayout {
                    padding: 10px;
                    Text { text: contact-name; font-size: 18px; font-weight: 700; color: #125f3d; }
                    Text { text: last-reply; font-size: 14px; color: #27332d; wrap: word-wrap; }
                }
            }
            if in-call: HorizontalLayout {
                spacing: 6px;
                Button { text: "Nasilsin?"; clicked => { root.send-message("Nasilsin?"); } }
                Button { text: "Ne yapalim?"; clicked => { root.send-message("Bugun ne yapalim?"); } }
                Button { text: "Oyun"; clicked => { root.send-message("Oyun oynayalim"); } }
            }
            if in-call: HorizontalLayout {
                spacing: 6px;
                Button { text: listening ? "Dinleniyor..." : "Otomatik dinleme"; enabled: false; }
                Button { text: "Bilmece"; clicked => { root.send-message("Bilmece sor"); } }
                Button { text: "Hikaye"; clicked => { root.send-message("Kisa hikaye anlat"); } }
                Button { text: "Tesekkur"; clicked => { root.send-message("Tesekkur ederim"); } }
            }
            HorizontalLayout {
                visible: in-call;
                height: 42px;
                spacing: 10px;
                if in-call: Button { text: "Kapat"; clicked => { root.end-call(); } }
            }
            if !in-call: HorizontalLayout {
                height: 48px;
                spacing: 4px;
                Button { text: "Klavye"; clicked => { phone-view = "keypad"; } }
                Button { text: "Son aramalar"; clicked => { phone-view = "recent"; } }
                Button { text: "Kisiler"; clicked => { phone-view = "contacts"; } }
            }
        }

        if screen == "settings": VerticalLayout {
            spacing: 14px;
            Text { text: "Medya ve arama sesi"; font-size: 18px; font-weight: 700; color: #151519; }
            Rectangle {
                height: 78px;
                background: #ffffff;
                border-color: #dedee4;
                border-width: 1px;
                border-radius: 8px;
                HorizontalLayout {
                    padding: 12px;
                    spacing: 12px;
                    Button {
                        text: "-";
                        width: 54px;
                        clicked => {
                            volume-percent = max(50, volume-percent - 25);
                            root.set-volume(volume-percent);
                        }
                    }
                    Text { horizontal-stretch: 1; text: volume-percent + "%"; font-size: 28px; font-weight: 700; color: #151519; horizontal-alignment: center; vertical-alignment: center; }
                    Button {
                        text: "+";
                        width: 54px;
                        enabled: volume-percent < 150;
                        clicked => {
                            volume-percent = min(150, volume-percent + 25);
                            root.set-volume(volume-percent);
                        }
                    }
                }
            }
            HorizontalLayout {
                spacing: 6px;
                Button { text: "50%"; clicked => { volume-percent = 50; root.set-volume(50); } }
                Button { text: "100%"; clicked => { volume-percent = 100; root.set-volume(100); } }
                Button { text: "125%"; clicked => { volume-percent = 125; root.set-volume(125); } }
                Button { text: "150%"; clicked => { volume-percent = 150; root.set-volume(150); } }
            }
            Button { text: "Sesi dene"; clicked => { root.test-sound(); } }
            Text { text: "En yuksek seviye 150%"; font-size: 13px; color: #777781; }
        }

        if screen == "recent-apps": VerticalLayout {
            spacing: 12px;
            Text { text: "Acik uygulamalar"; font-size: 18px; font-weight: 700; color: #151519; }
            Rectangle {
                height: 112px;
                background: #ffffff;
                border-color: #dedee4;
                border-width: 1px;
                border-radius: 8px;
                TouchArea { clicked => { screen = "phone"; } }
                VerticalLayout {
                    padding: 14px;
                    spacing: 6px;
                    Text { text: "Telefon"; font-size: 20px; font-weight: 700; color: #151519; }
                    Text { text: in-call ? contact-name + " ile gorusme suruyor" : "Tuş takımı ve rehber"; font-size: 13px; color: #686872; }
                }
            }
            Rectangle {
                height: 112px;
                background: #ffffff;
                border-color: #dedee4;
                border-width: 1px;
                border-radius: 8px;
                TouchArea { clicked => { screen = "home"; } }
                VerticalLayout {
                    padding: 14px;
                    spacing: 6px;
                    Text { text: "Pi Tablet"; font-size: 20px; font-weight: 700; color: #151519; }
                    Text { text: "Ana ekran"; font-size: 13px; color: #686872; }
                }
            }
        }

        Rectangle { vertical-stretch: 1; background: transparent; }

        Rectangle {
            height: 48px;
            background: #f2f2f6;
            border-color: #e1e1e6;
            border-width: 1px;
            HorizontalLayout {
                spacing: 0px;
                SystemNavKey {
                    symbol: "◁";
                    clicked => {
                        if in-call {
                            root.end-call();
                            screen = "home";
                        } else if screen == "phone" && phone-view != "keypad" {
                            phone-view = "keypad";
                        } else if screen != "home" {
                            screen = "home";
                        }
                    }
                }
                SystemNavKey {
                    symbol: "○";
                    clicked => {
                        if in-call {
                            root.end-call();
                        }
                        screen = "home";
                    }
                }
                SystemNavKey {
                    symbol: "□";
                    clicked => { screen = "recent-apps"; }
                }
            }
        }
    }
}
