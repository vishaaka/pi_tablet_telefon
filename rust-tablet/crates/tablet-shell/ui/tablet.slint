import { Button } from "std-widgets.slint";

export struct MenuItem {
    title: string,
    subtitle: string,
    tile-color: color,
    action: string,
    icon: string,
}

component AppTile inherits Rectangle {
    in property <string> title;
    in property <string> icon;
    in property <color> tile-color;
    callback clicked;
    background: transparent;
    height: 112px;
    TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        alignment: center;
        spacing: 6px;
        Rectangle {
            width: 68px;
            height: 68px;
            border-radius: 17px;
            background: tile-color;
            Text {
                text: icon;
                font-size: 35px;
                font-weight: 600;
                color: #202027;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        Text {
            text: title;
            height: 24px;
            font-size: 13px;
            font-weight: 600;
            color: #24242a;
            horizontal-alignment: center;
            overflow: elide;
        }
    }
}

component DialKey inherits Rectangle {
    in property <string> digit;
    in property <string> letters;
    callback clicked;
    background: transparent;
    height: 48px;
    TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        spacing: 0px;
        Text { text: digit; font-size: 29px; horizontal-alignment: center; color: #111115; }
        Text { text: letters; font-size: 10px; horizontal-alignment: center; color: #888891; }
    }
}

component SystemNavKey inherits Rectangle {
    in property <string> symbol;
    callback clicked;
    background: transparent;
    height: 46px;
    TouchArea { clicked => { root.clicked(); } }
    Text {
        text: symbol;
        font-size: 25px;
        color: #55555e;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component CallOption inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    callback clicked;
    background: transparent;
    height: 72px;
    TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        spacing: 4px;
        Text { text: icon; color: #30303a; font-size: 25px; horizontal-alignment: center; }
        Text { text: label; color: #555560; font-size: 11px; horizontal-alignment: center; }
    }
}

export component TabletShell inherits Window {
    title: "Pi Tablet";
    background: tablet-background;
    in-out property <string> tablet-title: "Pi Tablet";
    in-out property <color> tablet-background: #f7f7fa;
    in-out property <[MenuItem]> menu-items;
    in-out property <string> screen: "home";
    in-out property <string> dialed: "";
    in-out property <string> status: "Hazir";
    in-out property <bool> in-call: false;
    in-out property <string> call-state: "idle";
    in-out property <string> calling-phone: "";
    in-out property <string> contact-name: "";
    in-out property <string> last-reply: "";
    in-out property <bool> listening: false;
    in-out property <string> phone-view: "keypad";
    in-out property <string> suggested-name: "";
    in-out property <string> suggested-initial: "A";
    in-out property <string> suggested-phone: "";
    in-out property <int> volume-percent: 150;
    in-out property <bool> parent-exit-open: false;
    in-out property <string> parent-exit-question: "";
    in-out property <string> parent-exit-answer: "";
    callback open-app(string);
    callback phone-tone(string);
    callback set-volume(int);
    callback test-sound;
    callback start-call(string);
    callback send-message(string);
    callback listen;
    callback end-call;
    callback request-parent-exit;
    callback submit-parent-exit(string);

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        if !(screen == "phone" && call-state != "idle"): HorizontalLayout {
            height: 44px;
            Text { text: screen == "home" ? tablet-title : screen == "phone" ? "Telefon" : screen == "settings" ? "Ses ayarlari" : "Son uygulamalar"; font-size: 28px; font-weight: 700; color: #111115; }
            Text { horizontal-stretch: 1; text: status; horizontal-alignment: right; vertical-alignment: center; color: #676772; font-size: 13px; }
        }

        if screen == "home": VerticalLayout {
            spacing: 12px;
            GridLayout {
                spacing: 8px;
                for item[index] in menu-items: AppTile {
                    row: index / 4;
                    col: Math.mod(index, 4);
                    title: item.title;
                    icon: item.icon;
                    tile-color: item.tile-color;
                    clicked => { root.open-app(item.action); }
                }
            }
        }

        if screen == "phone": VerticalLayout {
            spacing: 6px;
            if call-state == "idle" && phone-view == "keypad": VerticalLayout {
                spacing: 5px;
                if suggested-name != "": Rectangle {
                    height: 54px;
                    background: transparent;
                    TouchArea { clicked => { dialed = suggested-phone; } }
                    HorizontalLayout {
                        spacing: 10px;
                        Rectangle {
                            width: 38px;
                            height: 38px;
                            border-radius: 19px;
                            background: #77c8bb;
                            Text { text: suggested-initial; color: white; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Text { text: suggested-name; font-size: 16px; color: #151519; vertical-alignment: center; }
                        Text { horizontal-stretch: 1; text: suggested-phone; font-size: 12px; color: #777781; horizontal-alignment: right; vertical-alignment: center; }
                    }
                }
                Rectangle { height: 54px; background: transparent; Text { text: dialed; font-size: 40px; horizontal-alignment: center; vertical-alignment: center; color: #111115; } }
                GridLayout {
                    height: suggested-name == "" ? 250px : 220px;
                    spacing: 6px;
                    DialKey { row: 0; col: 0; digit: "1"; letters: ""; clicked => { dialed += "1"; root.phone-tone("1"); } }
                    DialKey { row: 0; col: 1; digit: "2"; letters: "ABC"; clicked => { dialed += "2"; root.phone-tone("2"); } }
                    DialKey { row: 0; col: 2; digit: "3"; letters: "DEF"; clicked => { dialed += "3"; root.phone-tone("3"); } }
                    DialKey { row: 1; col: 0; digit: "4"; letters: "GHI"; clicked => { dialed += "4"; root.phone-tone("4"); } }
                    DialKey { row: 1; col: 1; digit: "5"; letters: "JKL"; clicked => { dialed += "5"; root.phone-tone("5"); } }
                    DialKey { row: 1; col: 2; digit: "6"; letters: "MNO"; clicked => { dialed += "6"; root.phone-tone("6"); } }
                    DialKey { row: 2; col: 0; digit: "7"; letters: "PQRS"; clicked => { dialed += "7"; root.phone-tone("7"); } }
                    DialKey { row: 2; col: 1; digit: "8"; letters: "TUV"; clicked => { dialed += "8"; root.phone-tone("8"); } }
                    DialKey { row: 2; col: 2; digit: "9"; letters: "WXYZ"; clicked => { dialed += "9"; root.phone-tone("9"); } }
                    DialKey { row: 3; col: 0; digit: "*"; letters: ""; clicked => { dialed += "*"; root.phone-tone("star"); } }
                    DialKey { row: 3; col: 1; digit: "0"; letters: "+"; clicked => { dialed += "0"; root.phone-tone("0"); } }
                    DialKey { row: 3; col: 2; digit: "#"; letters: ""; clicked => { dialed += "#"; root.phone-tone("hash"); } }
                }
                HorizontalLayout {
                    height: 68px;
                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;
                        Text { text: "▣"; color: #0aaa68; font-size: 29px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        width: 64px;
                        background: #0aaa68;
                        border-radius: 32px;
                        Text { text: "☎"; color: white; font-size: 30px; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea {
                            clicked => {
                                contact-name = suggested-name == "" ? (dialed == "" ? "Asya AI" : "Bilinmeyen Numara") : suggested-name;
                                calling-phone = suggested-phone == "" ? dialed : suggested-phone;
                                call-state = "ringing";
                                in-call = true;
                                status = "Araniyor...";
                                root.start-call(dialed);
                            }
                        }
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        background: transparent;
                        Text { text: dialed == "" ? "" : "⌫"; color: #777781; font-size: 27px; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea { enabled: dialed != ""; clicked => { dialed = ""; suggested-name = ""; suggested-phone = ""; } }
                    }
                }
            }
            if call-state == "idle" && phone-view == "contacts": VerticalLayout {
                spacing: 5px;
                Text { text: "Kisiler"; font-size: 22px; font-weight: 700; color: #151519; height: 32px; }
                GridLayout {
                height: 246px;
                spacing: 8px;
                Button { row: 0; col: 0; text: "Asya AI"; clicked => { dialed = ""; root.start-call(""); } }
                Button { row: 0; col: 1; text: "Deniz AI"; clicked => { dialed = "+905332022020"; root.start-call(dialed); } }
                Button { row: 1; col: 0; text: "Mira AI"; clicked => { dialed = "+905343033030"; root.start-call(dialed); } }
                Button { row: 1; col: 1; text: "Atlas AI"; clicked => { dialed = "+905354044040"; root.start-call(dialed); } }
                Button { row: 2; col: 0; text: "Zeynep AI"; clicked => { dialed = "+905365055050"; root.start-call(dialed); } }
                Button { row: 2; col: 1; text: "Kerem AI"; clicked => { dialed = "+905376066060"; root.start-call(dialed); } }
                }
            }
            if call-state == "idle" && phone-view == "recent": VerticalLayout {
                spacing: 8px;
                Text { text: "Son aramalar"; font-size: 22px; font-weight: 700; color: #151519; height: 32px; }
                Button { text: "Asya AI    Bugun"; clicked => { dialed = ""; root.start-call(""); } }
                Button { text: "Mira AI    Dun"; clicked => { dialed = "+905343033030"; root.start-call(dialed); } }
                Button { text: "Deniz AI    Dun"; clicked => { dialed = "+905332022020"; root.start-call(dialed); } }
            }
            if call-state != "idle": Rectangle {
                vertical-stretch: 1;
                background: #171522;
                VerticalLayout {
                    padding: 18px;
                    spacing: 10px;
                    Text { text: call-state == "ringing" ? "Araniyor..." : listening ? "Dinleniyor..." : "Gorusmede"; font-size: 16px; color: #e8e6ec; horizontal-alignment: center; }
                    Text { text: contact-name; font-size: 34px; font-weight: 700; color: white; horizontal-alignment: center; }
                    Text { text: calling-phone == "" ? "Cep" : "Cep  " + calling-phone; font-size: 15px; color: #eeeaf1; horizontal-alignment: center; }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                    if call-state == "connected": Rectangle {
                        height: 82px;
                        background: #ffffff18;
                        border-radius: 8px;
                        Text { text: last-reply; font-size: 14px; color: white; wrap: word-wrap; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    Rectangle {
                        height: 236px;
                        background: #eae7e8dd;
                        border-radius: 8px;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 8px;
                            GridLayout {
                                spacing: 4px;
                                CallOption { row: 0; col: 0; icon: "+"; label: "Arama ekle"; }
                                CallOption { row: 0; col: 1; icon: "▣"; label: "Video arama"; }
                                CallOption { row: 0; col: 2; icon: "ᛒ"; label: "Bluetooth"; }
                                CallOption { row: 1; col: 0; icon: "◖))"; label: "Hoparlor"; }
                                CallOption { row: 1; col: 1; icon: "♩"; label: listening ? "Dinleniyor" : "Sessiz"; }
                                CallOption { row: 1; col: 2; icon: "⠿"; label: "Tus takimi"; clicked => { call-state = "idle"; in-call = false; } }
                            }
                            HorizontalLayout {
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Rectangle {
                                    width: 66px;
                                    height: 66px;
                                    border-radius: 33px;
                                    background: #ea3d39;
                                    Text { text: "☎"; transform-rotation: 135deg; color: white; font-size: 29px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { clicked => { root.end-call(); } }
                                }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                            }
                        }
                    }
                }
            }
            if call-state == "idle": HorizontalLayout {
                height: 48px;
                spacing: 4px;
                Button { text: "Klavye"; clicked => { phone-view = "keypad"; } }
                Button { text: "Son aramalar"; clicked => { phone-view = "recent"; } }
                Button { text: "Kisiler"; clicked => { phone-view = "contacts"; } }
            }
        }

        if screen == "settings": VerticalLayout {
            spacing: 14px;
            Text { text: "Medya ve arama sesi"; font-size: 18px; font-weight: 700; color: #151519; }
            Rectangle {
                height: 78px;
                background: #ffffff;
                border-color: #dedee4;
                border-width: 1px;
                border-radius: 8px;
                HorizontalLayout {
                    padding: 12px;
                    spacing: 12px;
                    Button {
                        text: "-";
                        width: 54px;
                        clicked => {
                            volume-percent = max(50, volume-percent - 25);
                            root.set-volume(volume-percent);
                        }
                    }
                    Text { horizontal-stretch: 1; text: volume-percent + "%"; font-size: 28px; font-weight: 700; color: #151519; horizontal-alignment: center; vertical-alignment: center; }
                    Button {
                        text: "+";
                        width: 54px;
                        enabled: volume-percent < 150;
                        clicked => {
                            volume-percent = min(150, volume-percent + 25);
                            root.set-volume(volume-percent);
                        }
                    }
                }
            }
            HorizontalLayout {
                spacing: 6px;
                Button { text: "50%"; clicked => { volume-percent = 50; root.set-volume(50); } }
                Button { text: "100%"; clicked => { volume-percent = 100; root.set-volume(100); } }
                Button { text: "125%"; clicked => { volume-percent = 125; root.set-volume(125); } }
                Button { text: "150%"; clicked => { volume-percent = 150; root.set-volume(150); } }
            }
            Button { text: "Sesi dene"; clicked => { root.test-sound(); } }
            Text { text: "En yuksek seviye 150%"; font-size: 13px; color: #777781; }
        }

        if screen == "recent-apps": VerticalLayout {
            spacing: 12px;
            Text { text: "Acik uygulamalar"; font-size: 18px; font-weight: 700; color: #151519; }
            Rectangle {
                height: 112px;
                background: #ffffff;
                border-color: #dedee4;
                border-width: 1px;
                border-radius: 8px;
                TouchArea { clicked => { screen = "phone"; } }
                VerticalLayout {
                    padding: 14px;
                    spacing: 6px;
                    Text { text: "Telefon"; font-size: 20px; font-weight: 700; color: #151519; }
                    Text { text: in-call ? contact-name + " ile gorusme suruyor" : "Tuş takımı ve rehber"; font-size: 13px; color: #686872; }
                }
            }
            Rectangle {
                height: 112px;
                background: #ffffff;
                border-color: #dedee4;
                border-width: 1px;
                border-radius: 8px;
                TouchArea { clicked => { screen = "home"; } }
                VerticalLayout {
                    padding: 14px;
                    spacing: 6px;
                    Text { text: "Pi Tablet"; font-size: 20px; font-weight: 700; color: #151519; }
                    Text { text: "Ana ekran"; font-size: 13px; color: #686872; }
                }
            }
        }

        Rectangle { vertical-stretch: 1; background: transparent; }

        Rectangle {
            height: 48px;
            background: #f2f2f6;
            border-color: #e1e1e6;
            border-width: 1px;
            HorizontalLayout {
                spacing: 0px;
                SystemNavKey {
                    symbol: "◁";
                    clicked => {
                        if in-call {
                            root.end-call();
                            screen = "home";
                        } else if screen == "phone" && phone-view != "keypad" {
                            phone-view = "keypad";
                        } else if screen != "home" {
                            screen = "home";
                        }
                    }
                }
                SystemNavKey {
                    symbol: "○";
                    clicked => {
                        if in-call {
                            root.end-call();
                        }
                        screen = "home";
                    }
                }
                SystemNavKey {
                    symbol: "□";
                    clicked => { screen = "recent-apps"; }
                }
            }
        }
    }

    if !parent-exit-open: Rectangle {
        x: parent.width - 58px;
        y: 18px;
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: #ffffffcc;
        TouchArea { clicked => { root.request-parent-exit(); } }
        Text { text: "⏻"; font-size: 25px; color: #55555e; horizontal-alignment: center; vertical-alignment: center; }
    }

    if parent-exit-open: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #00000088;
        TouchArea { }
        Rectangle {
            width: 310px;
            height: 350px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #ffffff;
            border-radius: 8px;
            VerticalLayout {
                padding: 18px;
                spacing: 10px;
                Text { text: "Ebeveyn kontrolu"; font-size: 22px; font-weight: 700; color: #151519; horizontal-alignment: center; }
                Text { text: parent-exit-question; font-size: 27px; font-weight: 700; color: #151519; horizontal-alignment: center; }
                Text { text: parent-exit-answer == "" ? "Cevabi girin" : parent-exit-answer; font-size: 24px; color: #555560; horizontal-alignment: center; }
                GridLayout {
                    spacing: 6px;
                    Button { row: 0; col: 0; text: "1"; clicked => { parent-exit-answer += "1"; } }
                    Button { row: 0; col: 1; text: "2"; clicked => { parent-exit-answer += "2"; } }
                    Button { row: 0; col: 2; text: "3"; clicked => { parent-exit-answer += "3"; } }
                    Button { row: 1; col: 0; text: "4"; clicked => { parent-exit-answer += "4"; } }
                    Button { row: 1; col: 1; text: "5"; clicked => { parent-exit-answer += "5"; } }
                    Button { row: 1; col: 2; text: "6"; clicked => { parent-exit-answer += "6"; } }
                    Button { row: 2; col: 0; text: "7"; clicked => { parent-exit-answer += "7"; } }
                    Button { row: 2; col: 1; text: "8"; clicked => { parent-exit-answer += "8"; } }
                    Button { row: 2; col: 2; text: "9"; clicked => { parent-exit-answer += "9"; } }
                    Button { row: 3; col: 0; text: "Sil"; clicked => { parent-exit-answer = ""; } }
                    Button { row: 3; col: 1; text: "0"; clicked => { parent-exit-answer += "0"; } }
                    Button {
                        row: 3;
                        col: 2;
                        text: "Tamam";
                        clicked => {
                            root.submit-parent-exit(parent-exit-answer);
                            parent-exit-open = false;
                            parent-exit-answer = "";
                        }
                    }
                }
                Button { text: "Iptal"; clicked => { parent-exit-open = false; parent-exit-answer = ""; } }
            }
        }
    }
}
